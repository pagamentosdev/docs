{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "pagamentos.dev",
  "colors": {
    "primary": "#121212",
    "light": "#e5e5e5",
    "dark": "#121212"
  },
  "favicon": {
    "dark": "/favicon-light.svg",
    "light": "/favicon-dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentação",
        "groups": [
          {
            "group": "Introdução",
            "pages": ["index", "instalacao"]
          }
        ]
      },
      {
        "icon": "",
        "tab": "Guias",
        "groups": []
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://pagamentos.dev/blog",
          "icon": "newspaper"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/pagamentosdev/pagamentos",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/pagamentosdev/pagamentos"
    }
  },
  "contextual": {
    "display": "toc",
    "options": ["view", "chatgpt", "claude", "mcp"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/pagamentosdev",
      "github": "https://github.com/pagamentosdev",
      "discord": "https://discord.com/pagamentosdev"
    }
  }
}
