{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "pagamentos.dev",
  "colors": {
    "primary": "#121212",
    "light": "#e5e5e5",
    "dark": "#121212"
  },
  "background": {
    "color": {
      "dark": "#121212",
      "light": "#fff"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "dark": "vitesse-dark",
        "light": "vitesse-light"
      }
    }
  },
  "favicon": {
    "dark": "/favicon-light.svg",
    "light": "/favicon-dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentação",
        "groups": [
          {
            "group": "Fundamentos",
            "pages": ["index", "instalacao", "provedores", "integracoes"]
          },
          {
            "group": "Funcionalidades",
            "pages": [
              "features/cobrancas",
              "features/pagamentos",
              "features/checkout",
              "features/clientes",
              "features/webhooks"
            ]
          },
          {
            "group": "Provedores",
            "pages": [
              "provedores/mock",
              "provedores/abacatepay",
              "provedores/mercadopago",
              "provedores/woovi"
            ]
          },
          {
            "group": "Integrações",
            "pages": [
              "integracoes/angular",
              "integracoes/astro",
              "integracoes/convex",
              "integracoes/express",
              "integracoes/fastify",
              "integracoes/hono",
              "integracoes/nextjs",
              "integracoes/react",
              "integracoes/tanstack-start",
              "integracoes/vue"
            ]
          }
        ]
      },
      {
        "icon": "",
        "tab": "Guias",
        "groups": []
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://pagamentos.dev/blog",
          "icon": "newspaper"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/pagamentosdev/pagamentos",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/pagamentosdev/pagamentos"
    }
  },
  "contextual": {
    "display": "toc",
    "options": ["view", "chatgpt", "claude", "mcp"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/pagamentosdev",
      "github": "https://github.com/pagamentosdev",
      "discord": "https://discord.com/pagamentosdev"
    }
  }
}
